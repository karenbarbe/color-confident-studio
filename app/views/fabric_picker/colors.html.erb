<turbo-frame id="fabric_picker_content">
  <div class="py-2 h-80 overflow-y-auto" data-panel="colors">
    
    <% if @colors.empty? %>
      <div class="px-4 py-8 text-center text-sm text-base-content/50">
        No colors in this family
      </div>
    <% else %>
      <%= render partial: "fabric_picker/color_button", collection: @colors, as: :color %>
    <% end %>

  </div>
</turbo-frame>
