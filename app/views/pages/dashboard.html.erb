<div class="pt-3 md:pt-2 pb-20 space-y-30">
  <%# Flash messages container for Turbo Stream updates %>
  <div id="flash-messages" class="fixed top-4 right-4 z-100 space-y-2">
    <%= render "shared/flash", notice: notice, alert: alert %>
  </div>

  <%# Hero %>
  <section class="max-w-6xl mx-auto">
    <%# Grid %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
      
      <%# Row 1 %>
      <div class="bg-purple rounded-3xl md:col-span-3 p-8 md:p-10 flex justify-between items-center min-h-60 md:min-h-80">
        <div>
          <p class="text-white text-xl font-outfit font-medium mb-2">Hi <%= Current.user.first_name.capitalize %> <span class="text-3xl">👋</span></p>
          <h1 class="font-outfit text-4xl md:text-5xl lg:text-6xl text-white font-bold leading-none">
            Start<br>creating.
          </h1>
        </div>
       
        <div class="rounded-3xl flex items-center justify-center">
          <%= button_to palettes_path, method: :post, class: "group flex flex-col items-center justify-center" do %>
            <div class="w-32 h-32 md:w-40 md:h-40 rounded-full text-purple bg-white group-hover:bg-purple-dk group-hover:text-white transition-colors flex items-center justify-center cursor-pointer">
              <span class="font-outfit font-bold text-lg md:text-2xl text-center px-4">Create palette</span>
            </div>
          <% end %>
        </div>

      </div>

      <%# Row 2 - Steps %>
      <%# Step 1 %>
      <div class="bg-yellow-lg rounded-3xl p-6 md:p-8 md:min-h-60">
        <div class="flex flex-row md:flex-col lg:flex-row items-start gap-3 mb-3">
          <div class="size-12 rounded-full bg-purple text-white flex items-center justify-center font-outfit font-bold text-xl shrink-0">1</div>
          <div class="space-y-2 md:space-y-4">
            <h3 class="font-outfit font-bold text-xl md:text-2xl text-purple">Select a background color</h3>
            <p class="text-purple text-md font-semibold">Your fabric. Everything else reacts to it.</p>
          </div>
        </div>
      </div>

      <%# Step 2 %>
      <div class="bg-peach rounded-3xl p-6 md:p-8 md:min-h-60">
        <div class="flex flex-row md:flex-col lg:flex-row items-start gap-3 mb-3">
          <div class="size-12 rounded-full bg-purple text-white flex items-center justify-center font-outfit font-bold text-xl shrink-0">2</div>
          <div class="space-y-2 md:space-y-4">
            <h3 class="font-outfit font-bold text-xl md:text-2xl text-purple">Add up to 12 thread colors</h3>
            <p class="text-purple text-md font-semibold">Choose from any color chart. Mix brands just as you would in real life.</p>
          </div>
        </div>
      </div>

      <%# Step 3 %>
      <div class="bg-[#E0F4FC] rounded-3xl p-6 md:p-8 md:min-h-60">
        <div class="flex flex-row md:flex-col lg:flex-row items-start gap-3 mb-3">
          <div class="size-12 rounded-full bg-purple text-white flex items-center justify-center font-outfit font-bold text-xl shrink-0">3</div>
          <div class="space-y-2 md:space-y-4">
            <h3 class="font-outfit font-bold text-xl md:text-2xl text-purple">Tweak colors and have fun</h3>
            <p class="text-purple text-md font-semibold">Adjust, preview, and save when it feels right.</p>
          </div>
        </div>
      </div>

    </div>
  </section>


  <%# Recent palettes section %>
  <section>
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold text-base-content">Your palettes</h2>
      <% if @recent_palettes.any? %>
        <%= link_to "View all", palettes_path, class: "btn btn-neutral btn-small btn-link" %>
      <% end %>
    </div>

    <% if @recent_palettes.any? %>
      <div class="@container">
        <div class="grid grid-cols-1 @md:grid-cols-2 @xl:grid-cols-3 gap-4">
          <% @recent_palettes.each do |palette| %>
            <%= render "palettes/palette_card", palette: palette %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="border border-dashed border-base-300 rounded-xl p-8 text-center">
        <p class="text-base-content/60">Your recent palettes will appear here</p>
      </div>
    <% end %>
  </section>

  <%# Stash summary %>
  <%= render "stash_summary_card" %>

</div>
